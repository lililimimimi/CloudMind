{
  "nodes": [
    {
      "id": "包年包月 (Subscription)",
      "label": "BillingRule",
      "properties": [
        {
          "key": "适用场景",
          "value": "适用于 24 小时在线的稳定业务（如核心数据库 RDS、企业级 Web 服务器 ecs.g8a.xlarge）"
        },
        {
          "key": "计费规则",
          "value": "预付费模式。购买周期越长，折扣力度越大（例如：买一年 8.5 折，买三年 5 折）"
        }
      ]
    },
    {
      "id": "按量付费 (Pay-As-You-Go)",
      "label": "BillingRule",
      "properties": [
        {
          "key": "适用场景",
          "value": "适用于有明显波峰波谷的短期业务、开发测试环境或电商大促期间的临时扩容"
        },
        {
          "key": "计费规则",
          "value": "后付费模式。按秒计费，每小时整点出具账单。实例价格通常高于包年包月"
        }
      ]
    },
    {
      "id": "抢占式实例 (Spot Instance)",
      "label": "BillingRule",
      "properties": [
        {
          "key": "适用场景",
          "value": "适用于无状态的 Web 服务、离线数据分析、批量计算等对中断容忍度较高的业务"
        },
        {
          "key": "计费规则",
          "value": "价格随供需市场波动，最高可比按量付费节省 90%"
        },
        {
          "key": "保护期",
          "value": "创建后提供 1 小时的库存与价格保护期"
        },
        {
          "key": "自动释放机制",
          "value": "保护期结束后，如果市场价格高于您的出价，或者资源池库存不足，系统将在提前 5 分钟发送系统事件通知后，自动回收（释放）该实例。释放后数据将不可恢复"
        }
      ]
    },
    {
      "id": "停机不收费 (Stop and Free)",
      "label": "Feature",
      "properties": [
        {
          "key": "描述",
          "value": "当实例状态变为 `Stopped` 且开启了“停机不收费”时，计算资源（vCPU 和内存）将停止计费。云盘 (ESSD) 和保留的 EIP 无论是否关机都持续计费"
        }
      ]
    },
    {
      "id": "本地盘 (NVMe SSD)",
      "label": "Storage",
      "properties": [
        {
          "key": "描述",
          "value": "挂载了本地盘 (NVMe SSD) 的实例（如 i4 系列）或带有本地盘的 GPU 实例 (gn7i)，不支持停机不收费，关机后计算资源依然计费"
        }
      ]
    },
    {
      "id": "GPU 实例 (gn7i)",
      "label": "InstanceType",
      "properties": [
        {
          "key": "描述",
          "value": "带有本地盘的 GPU 实例，不支持停机不收费，关机后计算资源依然计费"
        }
      ]
    },
    {
      "id": "弹性公网 IP (EIP)",
      "label": "Feature",
      "properties": [
        {
          "key": "描述",
          "value": "公网带宽通常通过绑定弹性公网 IP (EIP) 来实现"
        }
      ]
    },
    {
      "id": "按固定带宽计费 (PayByBandwidth)",
      "label": "BillingRule",
      "properties": [
        {
          "key": "规则",
          "value": "按指定的带宽峰值（如 5 Mbps）收取固定费用，无论实际使用多少流量"
        },
        {
          "key": "适用场景",
          "value": "公网流量平稳且使用率高的业务"
        },
        {
          "key": "阶梯定价",
          "value": "通常 1-5 Mbps 单价较低，超过 5 Mbps 的部分单价会急剧上升"
        }
      ]
    },
    {
      "id": "按使用流量计费 (PayByTraffic)",
      "label": "BillingRule",
      "properties": [
        {
          "key": "规则",
          "value": "根据实际产生的出网流量 (Outbound) 按 GB 计费（例如 0.8 元/GB）。入网流量 (Inbound) 免费"
        },
        {
          "key": "适用场景",
          "value": "公网流量波动大，或者整体流量较少的业务。您可以将带宽峰值设置得很高（如 100 Mbps），以应对突发请求，而不必为高带宽支付固定费用"
        }
      ]
    },
    {
      "id": "五天无理由退款",
      "label": "Feature",
      "properties": [
        {
          "key": "条件",
          "value": "新购的“包年包月”实例，在购买后的 5 天内，且实例未发生过降配、续费等操作，支持全额退款"
        },
        {
          "key": "额度限制",
          "value": "每个实名认证账号，每个自然年仅享有 1 次“五天无理由退款”权益（一次最多退订 10 台实例）"
        }
      ]
    },
    {
      "id": "非全额退订 (按比例退款)",
      "label": "Feature",
      "properties": [
        {
          "key": "条件",
          "value": "超过 5 天后退订包年包月实例，或者不满足无理由退款条件"
        },
        {
          "key": "退款公式",
          "value": "退款金额 = 订单实付金额 - (已使用天数 × 按量付费单价) - (订单实付金额 × 15% 退订手续费)"
        },
        {
          "key": "注意",
          "value": "如果按照上述公式计算出的金额小于等于 0，则不予退款"
        }
      ]
    },
    {
      "id": "欠费与自动释放",
      "label": "Feature",
      "properties": [
        {
          "key": "描述",
          "value": "如果账户余额不足发生欠费，实例将进入“欠费停机”状态（保留数据 15 天）。超过 15 天未充值，实例及挂载的云盘将被彻底释放（销毁）"
        }
      ]
    }
  ],
